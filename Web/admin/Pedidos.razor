@page "/admin/pedidos"
@using Application.DTOs
@inject HttpClient Http
@inject IJSRuntime JS
@using System.Net.Http.Headers

<PageTitle>Control de Pedidos - Admin</PageTitle>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">📋 Control de Pedidos</h2>
    </div>

    @if (pedidos == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Buscando ventas...</p>
        </div>
    }
    else if (!pedidos.Any())
    {
        <div class="alert alert-info shadow-sm">
            Aún no hay pedidos registrados en la tienda.
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Nº Pedido</th>
                                <th>Fecha</th>
                                <th>Cliente</th>
                                <th>Total</th>
                                <th>Estado</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ped in pedidos)
                            {
                                <tr>
                                    <td class="fw-bold text-muted">#@ped.Id</td>
                                    <td>@ped.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@ped.ClienteEmail</td>
                                    <td class="text-success fw-bold">$@ped.Total</td>
                                    <td>
                                        <span class="badge bg-warning text-dark">@ped.Estado</span>
                                    </td>
                                    <td class="text-end">
                                        @if (ped.Estado == "Pendiente" || string.IsNullOrEmpty(ped.Estado))
                                        {
                                            <button class="btn btn-sm btn-primary shadow-sm me-2"
                                                    @onclick='() => CambiarEstado(ped.Id, "Enviado")'>
                                                🚚 Marcar Enviado
                                            </button>
                                        }
                                        else if (ped.Estado == "Enviado")
                                        {
                                            <button class="btn btn-sm btn-success shadow-sm me-2"
                                                    @onclick='() => CambiarEstado(ped.Id, "Entregado")'>
                                                ✅ Marcar Entregado
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary me-2">Finalizado</span>
                                        }

                                        <a href="/admin/pedidos/@ped.Id" class="btn btn-sm btn-outline-primary">
                                            👁️ Ver Detalle
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<PedidoAdminDto>? pedidos;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 1. Buscamos la llave VIP en la memoria del navegador
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");

            if (!string.IsNullOrEmpty(token))
            {
                // 2. Se la pegamos en la frente al cartero
                Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

                // 3. Ahora sí, pedimos los datos
                pedidos = await Http.GetFromJsonAsync<List<PedidoAdminDto>>("api/Pedidos");
            }
            else
            {
                Console.WriteLine("No se encontró el token de seguridad.");
                pedidos = new List<PedidoAdminDto>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error al cargar pedidos: " + ex.Message);
            pedidos = new List<PedidoAdminDto>();
        }
    }
    private async Task CambiarEstado(int id, string nuevoEstado)
    {
        try
        {
            // 1. Buscamos el Pase VIP
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");
            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

            // 2. Preparamos la cajita con el nuevo estado
            var peticion = new { NuevoEstado = nuevoEstado };

            // 3. Disparamos la actualización a la API
            var respuesta = await Http.PutAsJsonAsync($"api/Pedidos/{id}/estado", peticion);

            if (respuesta.IsSuccessStatusCode)
            {
                // 4. Si todo salió bien, volvemos a pedir la lista para que la pantalla se actualice sola
                await OnInitializedAsync();
            }
            else
            {
                Console.WriteLine("Error al cambiar el estado del pedido.");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error: " + ex.Message);
        }
    }
}