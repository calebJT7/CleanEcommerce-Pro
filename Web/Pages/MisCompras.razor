@page "/mis-compras"
@using System.Net.Http.Headers
@inject HttpClient Http
@inject IJSRuntime JSRuntime

<PageTitle>Mis Compras - CleanEcommerce</PageTitle>

<div class="container mt-4">
    <h2 class="mb-4 fw-bold">📦 Historial de Compras</h2>

    @if (cargando)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Buscando tus pedidos...</p>
        </div>
    }
    else if (misPedidos == null || !misPedidos.Any())
    {
        <div class="alert alert-info text-center shadow-sm py-5">
            <h4 class="fw-bold">Aún no tienes compras</h4>
            <p class="text-muted">Cuando realices un pedido, aparecerá aquí.</p>
            <a href="/" class="btn btn-dark mt-3">Ir a la tienda</a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var pedido in misPedidos)
            {
                <div class="col-12 mb-3">
                    <div class="card shadow-sm border-0">
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="fw-bold mb-1">Pedido #@pedido.Id</h5>
                                <span class="badge bg-success">Completado</span>
                            </div>
                            <div class="text-end">
                                <h4 class="text-success fw-bold mb-0">$@pedido.Total</h4>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private bool cargando = true;
    // Usamos dynamic por ahora, luego lo puedes cambiar por tu PedidoDto real
    private List<dynamic>? misPedidos;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 1. Buscamos tu Pase VIP
            var token = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "authToken");

            if (!string.IsNullOrEmpty(token))
            {
                // 2. Le pegamos el token al cartero
                Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

                // 3. Pedimos el historial a la API
                // IMPORTANTE: Revisa en Swagger cómo se llama exactamente esta ruta (ej. api/Pedidos)
                misPedidos = await Http.GetFromJsonAsync<List<dynamic>>("api/Pedidos");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error al cargar pedidos: " + ex.Message);
        }
        finally
        {
            cargando = false;
        }
    }
}